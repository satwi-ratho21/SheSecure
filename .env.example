# ==========================================
# VANGUARD SYSTEM CONFIGURATION TEMPLATE
# ==========================================

# ----------------- SERVER CONFIG -----------------
NODE_ENV=production
PORT=3000
JWT_SECRET=your_ultra_secure_jwt_secret_key_minimum_32_characters
CORS_ORIGIN=https://your-vercel-frontend-domain.vercel.app

# ----------------- AI COGNITIVE -----------------
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------- GOOGLE MAPS -----------------
GOOGLE_MAPS_PLATFORM_KEY=your_google_maps_api_key_with_geocoding_enabled

# ----------------- MONGO DATABASE -----------------
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/vanguard?retryWrites=true&w=majority

# ----------------- CLOUDINARY CDN -----------------
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ----------------- TWILIO CARRIER -----------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=your_purchased_twilio_phone_number_international_format
